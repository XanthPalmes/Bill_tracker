{
  "compilerOptions": {
    "target": "es2023",
    "module": "es2020",
    "lib": ["ES2023", "DOM"],
    "skipLibCheck": true,
  "ignoreDeprecations": "6.0",

    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
